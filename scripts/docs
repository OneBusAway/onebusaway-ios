#!/bin/bash
set -euo pipefail

# Regenerate the project so the build reflects the current project.yml
scripts/generate_project OneBusAway

# NOTE: Output goes to api-docs/, NOT docs/. The docs/ directory holds
# committed Markdown (specs, plans, guides) and must not be clobbered by the
# generated DocC site, which is published to GitHub Pages via CI.
DERIVED_DATA=".docc-build"
OUTPUT_DIR="api-docs"

# Build documentation archives (produces one per framework target)
xcodebuild docbuild \
  -scheme App \
  -destination 'generic/platform=iOS' \
  -derivedDataPath "$DERIVED_DATA" \
  -quiet

# Locate the .doccarchive files
CORE_ARCHIVE=$(find "$DERIVED_DATA" -type d -name 'OBAKitCore.doccarchive' | head -1)
KIT_ARCHIVE=$(find "$DERIVED_DATA" -type d -name 'OBAKit.doccarchive' | head -1)

# Merge into a combined archive with a synthesized landing page
xcrun docc merge \
  "$CORE_ARCHIVE" \
  "$KIT_ARCHIVE" \
  --output-path Combined.doccarchive

# Transform for static hosting
rm -rf "$OUTPUT_DIR"
xcrun docc process-archive transform-for-static-hosting \
  Combined.doccarchive \
  --output-path "$OUTPUT_DIR" \
  --hosting-base-path "${HOSTING_BASE_PATH:-}"

# Work around a docc bug: when merging archives, transform-for-static-hosting
# rewrites every page's baseUrl/asset paths for the hosting base path EXCEPT the
# synthesized root landing page (api-docs/index.html), which keeps baseUrl="/".
# On GitHub Pages (served under /<base>/) that leaves the landing page loading
# its JS/CSS from the domain root and 404ing. Apply the base path to it by hand.
if [ -n "${HOSTING_BASE_PATH:-}" ]; then
  base="/${HOSTING_BASE_PATH#/}"   # ensure exactly one leading slash
  base="${base%/}"                 # and no trailing slash
  root_index="$OUTPUT_DIR/index.html"
  if grep -q 'baseUrl = "/"' "$root_index"; then
    sed -i '' -E \
      -e "s#baseUrl = \"/\"#baseUrl = \"${base}/\"#g" \
      -e "s#(src|href)=\"/#\1=\"${base}/#g" \
      "$root_index"
  fi
fi

rm -rf "$DERIVED_DATA" Combined.doccarchive
